# ClickUp
CLICKUP_ACCESS_TOKEN=
CLICKUP_DEFAULT_WORKSPACE_ID=8451352
CLICKUP_WEBHOOK_TEAM_ID=8451352
CLICKUP_WEBHOOK_CUSTOM_TASK_IDS=true

# This is a dedicated high-entropy secret. Do not reuse an invoice webhook token.
INSPECTION_APP_WEBHOOK_TOKEN=
# Set automatically from the ClickUp API webhook's response. Do not expose it.
CLICKUP_API_WEBHOOK_SECRET=
# Leave false while testing the ClickUp Automation. True permits PDF generation and writeback.
INSPECTION_APP_APPLY=false
# Magna uses validated as the report-ready state. The worker moves success cases to PASSED.
INSPECTION_APP_TRIGGER_STATUSES=validated
INSPECTION_REPORT_SUCCESS_STATUS=PASSED
INSPECTION_REPORT_CANONICAL_PAYLOAD_FIELD_ID=14cba98e-7dd2-426b-90b6-5c88be5e27e4

# Microsoft Graph / SharePoint
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TIMEOUT_SECONDS=60

# Magna inspection workflow
INSPECTION_REPORT_CLICKUP_LIST_ID=901707774763
INSPECTION_REPORT_SHAREPOINT_HOSTNAME=mtmlogixmx.sharepoint.com
INSPECTION_REPORT_SHAREPOINT_SITE_PATH=/sites/MTMLogixTopManagement
# Per-task OneDrive Pictures URLs are used first. Set a source fallback only if required.
INSPECTION_REPORT_SOURCE_FOLDER_URL=
INSPECTION_REPORT_SOURCE_FOLDER_PATH=
# Leave blank to upload the report into the task's SharePoint VIN folder.
INSPECTION_REPORT_OUTPUT_FOLDER_URL=
INSPECTION_REPORT_OUTPUT_FOLDER_PATH=
INSPECTION_REPORT_LOCAL_OUTPUT_DIR=/tmp/inspection_reports/pdf
INSPECTION_REPORT_LOCAL_DOCX_OUTPUT_DIR=/tmp/inspection_reports/docx
INSPECTION_REPORT_MAX_SHAREPOINT_DEPTH=2
INSPECTION_REPORT_MAX_IMAGES_PER_REPORT=400
INSPECTION_REPORT_TEMPLATE_MAX_IMAGES_PER_SECTION=4
INSPECTION_REPORT_COMMENT_FIELD_IDS=9f7e2a56-a0ef-481a-b2d3-65dac825989b
INSPECTION_REPORT_PICTURE_FOLDER_FIELD_IDS=1bfac08a-6df3-4ea4-a581-5f4b41a97bb1
INSPECTION_REPORT_LINK_FIELD_IDS=2893af26-64a6-42bf-a010-2022c7186c9a
INSPECTION_REPORT_ATTACHMENT_FIELD_IDS=3a454367-98b8-4a8f-96d5-6f8872b1ada1
