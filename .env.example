BC_TENANT_ID=your-tenant-id
BC_CLIENT_ID=your-client-id
BC_CLIENT_SECRET=your-client-secret
BC_ENVIRONMENT=Production

# Legacy single-company fallback. Prefer market-specific settings below.
BC_COMPANY_ID=
BC_API_VERSION=v2.0
BC_TIMEOUT_SECONDS=30
BC_USER_AGENT=ContractingTool/0.1

# Default market profile for commands that do not pass --market.
BC_DEFAULT_MARKET=MX

# Mexico
BC_MARKET_MX_COMPANY_ID=
BC_MARKET_MX_LOCAL_CURRENCY_CODE=MXN
BC_MARKET_MX_SUPPORTED_CURRENCY_CODES=MXN,USD
BC_MARKET_MX_CUSTOM_PRICING_PATH=

# Guatemala
BC_MARKET_GT_COMPANY_ID=
BC_MARKET_GT_LOCAL_CURRENCY_CODE=GTQ
BC_MARKET_GT_SUPPORTED_CURRENCY_CODES=GTQ,USD
BC_MARKET_GT_CUSTOM_PRICING_PATH=

# Optional: point this at a custom API page/query that performs pricing lookup.
# Supported placeholders: {company_id}
# Example:
# BC_CUSTOM_PRICING_PATH=/api/contoso/pricing/v1.0/companies({company_id})/priceCalculations
BC_CUSTOM_PRICING_PATH=

# Optional: custom BC endpoint for non-standard customer invoicing fields such as
# CFDI Customer Name, invoice email, and local posting defaults.
# Supported placeholders: {company_id}, {customer_id}
# Example:
# BC_CUSTOMER_INVOICING_SYNC_PATH=/api/mtmlogix/customerSync/v1.0/companies({company_id})/customerInvoicing({customer_id})
BC_CUSTOMER_INVOICING_SYNC_PATH=

# Optional: GL accounts used when the invoice webhook creates GT/USD sales invoices
# from ClickUp charge fields.
BC_MARKET_GT_FREIGHT_ACCOUNT_NUMBER=
BC_MARKET_GT_INLAND_ACCOUNT_NUMBER=
BC_MARKET_GT_DESTINATION_ACCOUNT_NUMBER=

# ClickUp OAuth app settings for customer sync.
CLICKUP_CLIENT_ID=your-clickup-client-id
CLICKUP_CLIENT_SECRET=your-clickup-client-secret
CLICKUP_REDIRECT_URI=http://localhost:8000/clickup/oauth/callback
CLICKUP_ACCESS_TOKEN=
CLICKUP_TOKEN_TYPE=Bearer
CLICKUP_DEFAULT_WORKSPACE_ID=
CLICKUP_DEFAULT_CUSTOMER_LIST_ID=
CLICKUP_WEBHOOK_TOKEN=
CLICKUP_WEBHOOK_TEAM_ID=8451352
CLICKUP_WEBHOOK_CUSTOM_TASK_IDS=true

# Twilio WhatsApp -> ClickUp intake
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VALIDATE_SIGNATURE=true
# Optional: set this to the exact public webhook URL if proxying changes the request URL seen by FastAPI.
TWILIO_VALIDATE_URL=
WHATSAPP_CLICKUP_BOOKING_LIST_ID=
WHATSAPP_CLICKUP_OPERATIONS_LIST_ID=
WHATSAPP_CLICKUP_BOOKING_STATUS_NEW=New WhatsApp Lead
WHATSAPP_CLICKUP_TASK_NAME_PREFIX=Booking Intake
WHATSAPP_CLICKUP_TASK_SCAN_PAGES=3
WHATSAPP_CLICKUP_CUSTOMER_PHONE_FIELD_NAME=Customer Phone
WHATSAPP_CLICKUP_CUSTOMER_NAME_FIELD_NAME=Customer Name
WHATSAPP_CLICKUP_SOURCE_CHANNEL_FIELD_NAME=Source Channel
WHATSAPP_CLICKUP_SOURCE_CHANNEL_VALUE=WhatsApp
WHATSAPP_CLICKUP_CONVERSATION_ID_FIELD_NAME=Conversation ID
WHATSAPP_CLICKUP_LAST_MESSAGE_AT_FIELD_NAME=Last WhatsApp Message At
WHATSAPP_CLICKUP_LAST_MESSAGE_ID_FIELD_NAME=Last WhatsApp Message ID
WHATSAPP_CLICKUP_ROUTED_CUSTOMER_FIELD_NAME=
WHATSAPP_CLICKUP_CUSTOMER_DIRECTORY_LIST_ID=
WHATSAPP_CLICKUP_DIRECTORY_TASK_SCAN_PAGES=3
WHATSAPP_CLICKUP_DIRECTORY_PHONE_FIELD_NAMES=Contact Phone 1,Contact Phone Number,Phone,Customer Phone
WHATSAPP_CLICKUP_DIRECTORY_TARGET_LIST_FIELD_NAMES=WhatsApp Intake List ID,Operations List ID,Booking Intake List ID,Shipment Management EndPoint
WHATSAPP_CLICKUP_DIRECTORY_TARGET_LIST_FIELD_IDS=
WHATSAPP_CLICKUP_DIRECTORY_CUSTOMER_NAME_FIELD_NAMES=Business Central Legal Name,Clientes/,Customer Name
WHATSAPP_CLICKUP_DIRECTORY_ALLOWED_STATUSES=
# JSON array of exact-phone or prefix routing rules.
# Example:
# WHATSAPP_CLICKUP_ROUTE_RULES_JSON=[{"match_type":"exact_phone","pattern":"+5215512345678","list_id":"901600000001","customer_name":"SMARTSPACE"},{"match_type":"phone_prefix","pattern":"+502","list_id":"901600000099","customer_name":"GUATEMALA OPS"}]
WHATSAPP_CLICKUP_ROUTE_RULES_JSON=

# ClickUp -> BC invoice automation
CLICKUP_INVOICE_MARKET=GT
CLICKUP_INVOICE_CURRENCY=USD
CLICKUP_INVOICE_OK_FINOPS_STATUS=OK Finops
CLICKUP_INVOICE_READY_STATUS=Listo para facturar
CLICKUP_INVOICE_STATUS_FIELD_IDS=b436ff28-24d8-4a5a-9f7e-66623401dee1
CLICKUP_INVOICE_FINAL_STATUS=Facturada
CLICKUP_INVOICE_ETA_HORIZON_DAYS=10
# Keep false for bridge dry-run testing. Set true only when the webhook should update ClickUp and create BC invoices.
CLICKUP_INVOICE_WEBHOOK_APPLY=false
CLICKUP_INVOICE_PDF_FIELD_ID=5d67859a-1ae0-4cda-9f57-2a89bf1ff259
CLICKUP_INVOICE_ETA_FIELD_NAMES=ETA
CLICKUP_INVOICE_ETA_FIELD_IDS=736ddd1d-33da-4ff8-a128-f7f3f738987d
CLICKUP_INVOICE_CURRENCY_FIELD_NAMES=Invoice Currency,Currency
CLICKUP_INVOICE_REFERENCE_FIELD_NAMES=Reference,Customer Reference,PO Number
CLICKUP_INVOICE_SHIPMENT_BOOKING_FIELD_NAMES=Booking number/,Booking Number,Booking
CLICKUP_INVOICE_SHIPMENT_CONTAINER_FIELD_NAMES=Container(s) number(s)/,Container Numbers,Containers,Container
CLICKUP_INVOICE_DATE_FIELD_NAMES=Invoice Date
CLICKUP_INVOICE_POSTING_DATE_FIELD_NAMES=Posting Date
CLICKUP_INVOICE_DUE_DATE_FIELD_NAMES=Due Date
# Uses config/invoice_charge_mappings/gt.json by default when present.
CLICKUP_INVOICE_CHARGE_MAPPING_PATH=config/invoice_charge_mappings/gt.json
# Legacy fallback only when no charge mapping file is configured/present.
CLICKUP_INVOICE_FREIGHT_FIELD_NAMES=Freight
CLICKUP_INVOICE_INLAND_FIELD_NAMES=Inland
CLICKUP_INVOICE_DESTINATION_FIELD_NAMES=Destination Charges,Destination Charge
CLICKUP_INVOICE_BC_CUSTOMER_ID_FIELD_NAMES=Business Central Customer ID
CLICKUP_INVOICE_BC_CUSTOMER_NUMBER_FIELD_NAMES=Business Central Customer Number
CLICKUP_INVOICE_CUSTOMER_NAME_FIELD_NAMES=Invoice to (Consignee's name)
CLICKUP_INVOICE_CUSTOMER_NAME_FIELD_IDS=729c2b40-6a61-4908-b0ed-3d6f92e72bcd
CLICKUP_INVOICE_BC_INVOICE_NUMBER_FIELD_NAMES=Business Central Invoice Number
CLICKUP_INVOICE_BC_INVOICE_ID_FIELD_NAMES=Business Central Invoice ID

# Business Central -> ClickUp Revenue Guatemala posted invoice mirror.
# This Phase 1 job is intended to run first in dry-run mode, then from cron/Render.
CLICKUP_REVENUE_GT_WORKSPACE_ID=8451352
CLICKUP_REVENUE_GT_LIST_ID=901710831940
CLICKUP_REVENUE_GT_INVOICING_LIST_ID=152220606
# Required before apply mode can route sync failures into ClickUp.
CLICKUP_REVENUE_GT_EXCEPTION_LIST_ID=
CLICKUP_REVENUE_GT_DEFAULT_STATUS=vigente
BC_REVENUE_GT_MARKET=GT
BC_REVENUE_GT_INCREMENTAL_DAYS=14
BC_REVENUE_GT_WEEKLY_FULL_DAYS=120
BC_REVENUE_GT_PAGE_SIZE=100
CLICKUP_REVENUE_GT_MAX_TASK_PAGES=10
CLICKUP_REVENUE_GT_ATTACH_DOCUMENTS=true
# Optional JSON overrides for Revenue Guatemala field-name registry.
# Example:
# CLICKUP_REVENUE_GT_FIELD_NAMES_JSON={"collection_status":["Collection Estatus"],"currency":["Currency Invoice"],"customer":["Customer"],"carrier":["Carrier/"]}
CLICKUP_REVENUE_GT_FIELD_NAMES_JSON=

# Truck physical inspection PDF reports
# Microsoft Graph can reuse the BC app values only if that Entra app has Graph
# SharePoint permissions. Otherwise set dedicated GRAPH_* credentials.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TIMEOUT_SECONDS=30
GRAPH_USER_AGENT=ContractingTool/0.1
INSPECTION_REPORT_CLICKUP_LIST_ID=
INSPECTION_REPORT_SHAREPOINT_HOSTNAME=mtmlogixmx.sharepoint.com
INSPECTION_REPORT_SHAREPOINT_SITE_PATH=/sites/Magna
# Prefer folder sharing URLs when available. Paths are relative to the SharePoint
# document library root used by Graph.
INSPECTION_REPORT_SOURCE_FOLDER_URL=
INSPECTION_REPORT_OUTPUT_FOLDER_URL=
INSPECTION_REPORT_SOURCE_FOLDER_PATH=Inspection Photos
INSPECTION_REPORT_OUTPUT_FOLDER_PATH=Inspection Reports
INSPECTION_REPORT_LOCAL_OUTPUT_DIR=output/pdf
INSPECTION_REPORT_LOCAL_DOCX_OUTPUT_DIR=output/docx
INSPECTION_REPORT_TEMPLATE_DOCX_PATH=
INSPECTION_REPORT_MAX_SHAREPOINT_DEPTH=2
INSPECTION_REPORT_MAX_IMAGES_PER_REPORT=400
INSPECTION_REPORT_TEMPLATE_MAX_IMAGES_PER_SECTION=4
INSPECTION_REPORT_ALLOWED_STATUSES=passed
INSPECTION_REPORT_FIELD_NAMES=Brand,Model,Color,Motor,Destination Country,Inspection Date,VIN Picture,Nameplate,360 Overview Result,360 Overview Comment,Corrosion Result,Accessories Result,Door Result,Floor Result,Emergency exits Result,Window Result,Seat Appearance / Fixation Result,Glass Result,Tire and Wheel Result,Exterior Lights Result,Painting Result,Mirrors Result,VIN number,Inspection Result Summary,Line,Branding Result,Car keys in glove box,OneDrive Pictures,Number of seats,Inspector Name,Rate Type,Previo en origen (USD),Detención al cliente (DB),Proforma Invoice,Type of cargo,Origin Inspection Report,Proforma,Excel report,Cargo Inspection Invoice,Inspection Final Report URL,Magna Shipments
INSPECTION_REPORT_COMMENT_FIELD_IDS=
INSPECTION_REPORT_COMMENT_FIELD_NAMES=Inspection AI Exec Summary
INSPECTION_REPORT_IMAGE_MATCH_FIELD_NAMES=VIN number
INSPECTION_REPORT_SHAREPOINT_FOLDER_FIELD_NAMES=OneDrive Pictures
INSPECTION_REPORT_PICTURE_FOLDER_FIELD_IDS=1bfac08a-6df3-4ea4-a581-5f4b41a97bb1
INSPECTION_REPORT_PICTURE_FOLDER_FIELD_NAMES=OneDrive Pictures
INSPECTION_REPORT_SECTION_FOLDER_PREFIXES=Car Information=01-Car Information,Car Information=1.Car Information,General / 360° Overview=02-General360,General / 360° Overview=2.General360,Corrosion Details=03-Corrosion,Corrosion Details=3.Corrosion,Accessories=04-Accessories,Accessories=4.Accessories,Door Adjustment and Operation=05-Door,Door Adjustment and Operation=5.Door,Floor Placement=06-Floor,Floor Placement=6.Floor,Window Operation and Condition=08-Window,Window Operation and Condition=8.Window,Glass Condition=09-Glass,Glass Condition=9.Glass,Inner Appearance and Fixation of Seats=10-Inner,Inner Appearance and Fixation of Seats=10.Inner,Tire and Wheel Condition=11-Tire,Tire and Wheel Condition=11.Tire,Exterior Lights Condition=12-Exterior,Exterior Lights Condition=12.Exterior,Painting Condition=13-Painting,Painting Condition=13.Painting,Mirrors Condition=14-Mirrors,Mirrors Condition=14.Mirrors
INSPECTION_REPORT_LINK_FIELD_IDS=
INSPECTION_REPORT_LINK_FIELD_NAMES=Inspection Report Link,Inspection Report,Physical Inspection Report
INSPECTION_REPORT_ATTACHMENT_FIELD_IDS=3a454367-98b8-4a8f-96d5-6f8872b1ada1
INSPECTION_REPORT_ATTACHMENT_FIELD_NAMES=Origin Inspection Report
INSPECTION_REPORT_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp
